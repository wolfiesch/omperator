{
  "name": "@t4-code/host-wire",
  "version": "0.1.31",
  "type": "module",
  "description": "Dependency-free T4 host protocol frames and bounded decoders",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "files": ["src", "fixtures/v1", "README.md", "CHANGELOG.md", "LICENSE"],
  "scripts": {
    "build": "bun run typecheck",
    "check": "bun run typecheck",
    "check:types": "tsgo -p tsconfig.json --noEmit && tsgo -p tsconfig.strict.json --noEmit",
		"test": "bun test test",
    "typecheck": "tsgo -p tsconfig.json --noEmit && tsgo -p tsconfig.strict.json --noEmit",
    "typecheck:strict": "tsgo -p tsconfig.strict.json --noEmit",
    "fix": "vp fmt --write .",
    "fmt": "vp fmt --write ."
  },
  "devDependencies": {
    "@types/bun": "1.3.5",
    "@types/node": "24.12.4",
    "typescript": "~6.0.3",
    "vite-plus": "0.2.2"
  },
  "engines": { "bun": ">=1.3.14" }
}
